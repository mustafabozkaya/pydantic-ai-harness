#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: get-ci-failure-logs <pr_number> [repo]" >&2
  exit 1
fi

PR_NUM="$1"
REPO="${2:-$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "")}"
[[ -z "$REPO" ]] && { echo "Error: could not auto-detect repo. Pass repo as second argument." >&2; exit 1; }

FAILED_LINK=$(gh pr checks "$PR_NUM" --repo "$REPO" --json name,state,link \
  -q '.[] | select(.state == "FAILURE" and (.name | startswith("test"))) | .link' \
  | head -1)

if [[ -z "$FAILED_LINK" ]]; then
  echo "No failed test checks for PR #$PR_NUM"
  exit 0
fi

RUN_ID=$(echo "$FAILED_LINK" | grep -oE 'runs/[0-9]+' | cut -d'/' -f2)

echo "PR #$PR_NUM — Run $RUN_ID"
echo "$FAILED_LINK"
echo ""

gh run view "$RUN_ID" --repo "$REPO" --log-failed 2>&1 \
  | grep -A 15 "Summary of Failures" \
  | grep -v "^check" \
  | awk -F'\t' '{
      content = $NF
      sub(/^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.Z]+[ ]?/, "", content)
      print content
  }' \
  | grep -v "##\[error\]"
